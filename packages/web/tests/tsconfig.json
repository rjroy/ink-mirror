{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["../*"]
    },
    "types": ["bun-types"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "references": [
    { "path": "../../shared" }
  ]
}
