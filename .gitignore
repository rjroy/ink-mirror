# Dependencies
node_modules/

# Build output
dist/
.next/
out/

# Environment and secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.idea/
.vscode/

# TypeScript
*.tsbuildinfo
*.d.ts.map

# Prevent tsc emit artifacts in source dirs (Next.js uses noEmit)
packages/web/**/*.js
!packages/web/*.config.js
!packages/web/*.config.mjs
packages/web/**/*.d.ts
!packages/web/next-env.d.ts

# Unix socket (daemon runtime)
*.sock
